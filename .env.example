# =============================================================================
# Bloom & Grow LMS — Environment Variables
# Copy this file to .env and fill in your values
# =============================================================================

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:pass@host.neon.tech/bloom_lms?sslmode=require

# Authentication
JWT_SECRET=change-me-to-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-to-another-long-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Slack (CompLeaveBot)
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Google Calendar
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/api/auth/google/callback

# Google Sheets (CompLeaveBot — service account auth)
# Paste the entire JSON content of your service account key file as a single line
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
# The Google Spreadsheet ID from the sheet URL (between /d/ and /edit)
GOOGLE_SPREADSHEET_ID=1abc-your-spreadsheet-id-xyz

# Cloudinary (file uploads — medical certificates, attachments)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# App
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173
